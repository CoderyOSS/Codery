# === System Container ===
TAILSCALE_AUTH_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# GitHub App identity (shared by both containers)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app.pem

# SSH directory (mounted read-only into system container for git operations)
SSH_DIR=~/.ssh

# === Sandbox Container ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# Domain (wildcard DNS — e.g. example.com for *.example.com)
DOMAIN_NAME=

# Timezone
TZ=UTC
