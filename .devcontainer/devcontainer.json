{
  "name": "Codery",
  "customizations": {
    "codery": {
      "sandbox": {
        "services": [
          {
            "name": "opencode",
            "command": [
              "opencode", "serve",
              "--hostname", "0.0.0.0",
              "--port", "3000"
            ],
            "user": "gem",
            "directory": "/home/gem/projects",
            "env": { "HOME": "/home/gem" },
            "restart": "always"
          },
          {
            "name": "opencode-diff-pruner",
            "command": ["/usr/local/bin/prune-opencode-diffs"],
            "user": "gem",
            "env": { "HOME": "/home/gem" },
            "restart": "always",
            "priority": 20
          },
          {
            "name": "opencode-serve-guard",
            "command": ["/usr/local/bin/opencode-serve-guard"],
            "user": "gem",
            "env": { "HOME": "/home/gem" },
            "restart": "always",
            "priority": 21
          },
          {
            "name": "sshd",
            "command": ["/usr/sbin/sshd", "-D", "-e"],
            "user": "root",
            "restart": "always",
            "priority": 10
          },
          {
            "name": "tmux",
            "command": ["bash", "-c", "tmux new-session -d -s main 2>/dev/null || true; exec sleep infinity"],
            "user": "gem",
            "directory": "/home/gem/projects",
            "env": { "HOME": "/home/gem" },
            "restart": "always"
          },
          {
            "name": "opendesign",
            "command": ["node", "/home/gem/open-design/apps/daemon/dist/cli.js", "--no-open"],
            "user": "gem",
            "directory": "/home/gem/open-design",
            "env": {
              "HOME": "/home/gem",
              "NODE_ENV": "production",
              "NODE_OPTIONS": "--max-old-space-size=192",
              "OD_BIND_HOST": "0.0.0.0",
              "OD_PORT": "7456",
              "OD_DISABLE_API_AUTH": "1"
            },
            "restart": "always",
            "priority": 30
          }
        ]
      },
      "apps": []
    }
  }
}
